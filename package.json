{
  "name": "shatterapp",
  "version": "1.3.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "scrape": "tsx scraper/scrape.ts",
    "scrape:retry": "tsx scraper/scrape.ts --retry",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx server/db/migrate.ts",
    "seed": "tsx server/db/seed.ts",
    "server": "tsx server/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\"",
    "images:compress": "tsx scripts/compress-images.ts",
    "images:deploy": "firebase deploy --only hosting"
  },
  "dependencies": {
    "@vercel/analytics": "^1.6.1",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "pinia": "^2.3.1",
    "pinia-plugin-persistedstate": "^3.2.3",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^3.0.6",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "firebase-tools": "^15.8.0",
    "happy-dom": "^17.3.1",
    "sharp": "^0.34.5",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.0.6",
    "tsx": "^4.19.2",
    "typescript": "~5.7.2",
    "vite": "^6.1.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.0.6",
    "vue-tsc": "^2.2.0"
  }
}
